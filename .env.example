# Configuración de API Keys
# Copia este archivo a .env y añade tus claves reales

# OpenAI API Key
OPENAI_API_KEY=tu_clave_de_openai_aqui

# Gemini API Key (opcional - para balanceo de carga)
GEMINI_API_KEY=tu_clave_de_gemini_aqui

# Configuración de proveedor de IA
# Opciones: 'openai', 'gemini', 'auto' (balanceo automático)
AI_PROVIDER=auto
